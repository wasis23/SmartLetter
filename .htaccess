RewriteEngine on

# 1. Proxy API requests ke backend Node.js (port 5000)
# Pastikan modul proxy Apache sudah aktif (a2enmod proxy proxy_http)
RewriteRule ^api/(.*)$ http://127.0.0.1:5000/api/$1 [P,L]

# 2. Jika request menargetkan file atau folder yang ada, langsung sajikan
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Rute SPA: Arahkan semua request non-file ke frontend/dist/index.html
RewriteCond %{REQUEST_URI} !^/frontend/dist/
RewriteRule ^(.*)$ frontend/dist/index.html [L]